{
  "name": "waveapi",
  "version": "1.0.0",
  "description": "NodeJS server with TypeScript",
  "scripts": {
    "dev": "tsx --watch --env-file .env src/index.ts",
    "start": "node --env-file .env dist/index.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zubairmoerat/waveAPI.git"
  },
  "keywords": [],
  "author": "Zubair Moerat",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/zubairmoerat/waveAPI/issues"
  },
  "homepage": "https://github.com/zubairmoerat/waveAPI#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-plugin-perfectionist": "^5.6.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "imports": {
    "#*": "./src/*"
  },
  "overrides": {
  "hono": "^4.10.3",
  "valibot": "^1.2.0"
  }
}
